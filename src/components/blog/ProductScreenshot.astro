---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

// Framed, optimized product screenshot with an optional caption.
// Import the image in your MDX and pass it in:
//   import shot from './intent-panel.png';
//   <ProductScreenshot src={shot} alt="The intent panel" caption="Active intent in Muninn" />
interface Props {
  src: ImageMetadata;
  alt: string;
  caption?: string;
}

const { src, alt, caption } = Astro.props;
---

<figure class="my-8">
  <div class="overflow-hidden rounded-xl border border-kawa-border bg-kawa-surface">
    <Image
      src={src}
      alt={alt}
      class="w-full"
      widths={[480, 800, 1200]}
      sizes="(max-width: 768px) 100vw, 768px"
    />
  </div>
  {
    caption && (
      <figcaption class="mt-2 text-center text-xs text-kawa-muted">{caption}</figcaption>
    )
  }
</figure>
