---
import { getCollection, render } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import BlogPost from '../layouts/BlogPost.astro';
import { parsePostId, postUrl } from '../i18n/utils';
import { type Lang } from '../i18n/ui';

const LANG: Lang = 'en';

export const getStaticPaths = (async () => {
  const all = await getCollection('blog');
  const byLang = all.map((post) => ({ post, meta: parsePostId(post.id) }));

  return byLang
    .filter(({ meta }) => meta.lang === 'en')
    .map(({ post, meta }) => {
      // Does a translation with the same slug exist?
      const hasJa = byLang.some((p) => p.meta.lang === 'ja' && p.meta.slug === meta.slug);
      const alternates: Partial<Record<Lang, string>> = { en: postUrl('en', meta.slug) };
      if (hasJa) alternates.ja = postUrl('ja', meta.slug);

      return { params: { slug: meta.slug }, props: { post, alternates } };
    });
}) satisfies GetStaticPaths;

const { post, alternates } = Astro.props;
const { slug } = parsePostId(post.id);
const { Content } = await render(post);
---

<BlogPost
  lang={LANG}
  slug={slug}
  title={post.data.title}
  description={post.data.description}
  pubDate={post.data.pubDate}
  updatedDate={post.data.updatedDate}
  author={post.data.author}
  tags={post.data.tags}
  heroImage={post.data.heroImage}
  alternates={alternates}
>
  <Content />
</BlogPost>
