---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { useTranslations, parsePostId } from '../../i18n/utils';
import { type Lang } from '../../i18n/ui';

const lang: Lang = 'ja';
const t = useTranslations(lang);

const posts = (
  await getCollection('blog', ({ data }) => (import.meta.env.PROD ? !data.draft : true))
)
  .map((post) => ({ post, meta: parsePostId(post.id) }))
  .filter(({ meta }) => meta.lang === lang)
  .sort((a, b) => b.post.data.pubDate.valueOf() - a.post.data.pubDate.valueOf());

const alternates = { en: '/', ja: '/ja/' };
---

<BaseLayout lang={lang} alternates={alternates} image="/og/home/ja.png">
  <section class="mb-12">
    <h1 class="text-4xl font-bold tracking-tight sm:text-5xl">{t('home.heading')}</h1>
    <p class="mt-4 max-w-2xl text-lg text-kawa-muted">{t('home.intro')}</p>
  </section>

  <section>
    <h2 class="mb-5 text-sm font-semibold uppercase tracking-wider text-kawa-muted">
      {t('home.latest')}
    </h2>
    <div class="grid gap-4">
      {
        posts.map(({ post, meta }) => (
          <PostCard
            lang={lang}
            slug={meta.slug}
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            tags={post.data.tags}
          />
        ))
      }
    </div>
  </section>
</BaseLayout>
