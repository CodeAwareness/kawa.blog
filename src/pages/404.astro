---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getLangFromUrl, localizedPath } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
---

<BaseLayout lang={lang} title="404">
  <div class="flex flex-col items-center py-20 text-center">
    <p class="text-6xl font-bold text-kawa-accent">404</p>
    <h1 class="mt-4 text-2xl font-semibold">Page not found</h1>
    <a
      href={localizedPath('/', lang)}
      class="mt-6 rounded-lg border border-kawa-border px-4 py-2 text-sm text-kawa-muted transition-colors hover:border-kawa-accent hover:text-kawa-accent"
    >
      ← Home
    </a>
  </div>
</BaseLayout>
